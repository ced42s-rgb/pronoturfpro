# ============================================================
# PRONOTURF PRO — Variables d'environnement
# ============================================================
# NE PAS committer ce fichier avec de vraies valeurs !
# Copie ces variables dans Netlify → Environment variables
# ============================================================

# ── STRIPE ──────────────────────────────────────────────────
# Webhook secret (Stripe Dashboard → Webhooks → ton endpoint)
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER_PAR_TON_SECRET

# ── AIRTABLE ─────────────────────────────────────────────────
# Clé API personnelle (airtable.com/account)
AIRTABLE_API_KEY=pat_REMPLACER_PAR_TA_CLE

# ID de ta base (dans l'URL : airtable.com/appXXXXX/...)
AIRTABLE_BASE_ID=appREMPLACER_PAR_TON_ID

# Nom exact de ta table (respecte les accents)
AIRTABLE_TABLE_NAME=Abonnés

# ── EMAILJS ──────────────────────────────────────────────────
# ID du service email (emailjs.com → Email Services)
EMAILJS_SERVICE_ID=service_REMPLACER

# ID du template "Bienvenue + PIN"
EMAILJS_TEMPLATE_ID=template_REMPLACER_BIENVENUE

# ID du template "Annulation" (optionnel, sinon même template)
EMAILJS_TEMPLATE_ANNULATION_ID=template_REMPLACER_ANNULATION

# Clé publique (emailjs.com → Account → API Keys)
EMAILJS_PUBLIC_KEY=user_REMPLACER

# Clé privée (emailjs.com → Account → API Keys)
EMAILJS_PRIVATE_KEY=pk_REMPLACER

# ── ADMIN ────────────────────────────────────────────────────
# Mot de passe pour accéder au dashboard admin dans l'app
# Choisis un mot de passe fort !
ADMIN_SECRET=CHOISIR_MON_MOT_DE_PASSE_ADMIN
